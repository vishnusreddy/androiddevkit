---
import DifficultyBadge from './DifficultyBadge.astro';
interface Props {
  id: string;
  question: string;
  difficulty: string;
  tags?: string[];
  /** Frequently asked / high-priority interview question. */
  starred?: boolean;
  topicTitle?: string;
  topicHref?: string;
  /** When true the answer starts expanded. */
  open?: boolean;
  /** Show the "mark as done" progress toggle. */
  trackable?: boolean;
}
const {
  id,
  question,
  difficulty,
  tags = [],
  starred = false,
  topicTitle,
  topicHref,
  open = false,
  trackable = true,
} = Astro.props;
---
<details class="qitem" id={id} open={open}>
  <summary>
    <div class="q-head">
      <span class="q-title">
        {starred && (
          <span
            class="priority-star"
            title="Frequently asked: study this first"
            aria-label="Frequently asked question"
          >
            <svg width="17" height="17" viewBox="0 0 24 24" aria-hidden="true">
              <path d="m12 2.8 2.8 5.67 6.26.91-4.53 4.42 1.07 6.24L12 17.1l-5.6 2.94 1.07-6.24-4.53-4.42 6.26-.91L12 2.8Z" />
            </svg>
          </span>
        )}
        <span class="q-text">{question}</span>
      </span>
      <svg class="chev" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </div>
    <div class="q-meta">
      <DifficultyBadge level={difficulty} />
      {topicTitle && topicHref && (
        <a class="q-topic" href={topicHref}>{topicTitle}</a>
      )}
      {tags.map((t) => <span class="q-tag">#{t}</span>)}
      {trackable && (
        <label class="q-done" title="Mark this question as studied">
          <input
            class="q-done-input"
            type="checkbox"
            data-progress-id={id}
            aria-label={`Mark "${question}" as done`}
          />
          <svg class="q-done-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
          <span class="q-done-text">Mark done</span>
          <span class="q-done-text-on">Done</span>
        </label>
      )}
    </div>
  </summary>
  <div class="q-answer prose">
    {difficulty === 'senior' && (
      <p class="advanced-note">
        <strong>Optional deep dive:</strong> This is useful after you are
        comfortable with the everyday version of the topic. Focus on the main
        idea first; the implementation details are a senior-level follow-up.
      </p>
    )}
    <slot />
  </div>
</details>

<style>
  .qitem {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    margin-bottom: 0.85rem;
    overflow: hidden;
    transition: border-color 0.15s ease;
    scroll-margin-top: 90px;
  }
  .qitem[open] {
    border-color: var(--border-strong);
  }
  .qitem:hover {
    border-color: var(--accent);
  }
  .qitem.is-done {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent-soft) 55%, var(--surface));
  }
  .qitem.is-done .q-text {
    color: var(--ink-soft);
  }
  summary {
    list-style: none;
    cursor: pointer;
    padding: 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  summary::-webkit-details-marker {
    display: none;
  }
  .q-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }
  .q-text {
    font-weight: 600;
    font-size: 1.02rem;
    color: var(--ink);
    line-height: 1.45;
  }
  .q-title {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    min-width: 0;
  }
  .priority-star {
    display: inline-flex;
    flex: 0 0 auto;
    margin-top: 0.2rem;
    color: #b7791f;
  }
  .priority-star svg {
    display: block;
    fill: currentColor;
  }
  :global(:root[data-theme='dark']) .priority-star {
    color: #f4bf58;
  }
  .chev {
    flex-shrink: 0;
    color: var(--ink-faint);
    margin-top: 2px;
    transition: transform 0.2s ease;
  }
  .qitem[open] .chev {
    transform: rotate(180deg);
  }
  .q-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .q-topic {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.18rem 0.6rem;
  }
  .q-topic:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .q-tag {
    font-size: 0.78rem;
    color: var(--ink-faint);
  }

  /* "Mark done" toggle: a real checkbox styled as a pill, pushed to the right. */
  .q-done {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    padding: 0.2rem 0.62rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    cursor: pointer;
    user-select: none;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .q-done:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .q-done-input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    margin: 0;
  }
  .q-done-check {
    opacity: 0.45;
    flex-shrink: 0;
  }
  .q-done-text-on {
    display: none;
  }
  .q-done-input:focus-visible + .q-done-check {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 3px;
  }
  /* Checked state */
  .q-done:has(.q-done-input:checked) {
    color: var(--on-accent);
    background: var(--accent);
    border-color: var(--accent);
  }
  .q-done:has(.q-done-input:checked):hover {
    color: var(--on-accent);
    background: var(--accent-hover);
  }
  .q-done:has(.q-done-input:checked) .q-done-check {
    opacity: 1;
  }
  .q-done:has(.q-done-input:checked) .q-done-text {
    display: none;
  }
  .q-done:has(.q-done-input:checked) .q-done-text-on {
    display: inline;
  }
  .q-answer {
    padding: 0.25rem 1.25rem 1.35rem;
    border-top: 1px solid var(--border);
    margin-top: -0.2rem;
  }
  .q-answer :global(p:first-child) {
    margin-top: 0.9rem;
  }
  .q-answer :global(p) {
    color: var(--ink-soft);
  }
  .q-answer :global(li) {
    color: var(--ink-soft);
  }
  .q-answer :global(pre) {
    margin: 1rem 0;
  }
  .advanced-note {
    padding: 0.75rem 0.85rem;
    border-left: 3px solid var(--accent);
    background: var(--accent-soft);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    font-size: 0.9rem;
  }
</style>

<script>
  // Wires up "mark done" toggles and keeps them in sync with stored progress.
  import '../lib/progress';
</script>
