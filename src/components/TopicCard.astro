---
interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  icon: string;
  count: number;
  /** Question ids for this topic, used to render a client-side progress bar. */
  ids?: string[];
}
const { href, title, description, category, icon, count, ids = [] } =
  Astro.props;
---
<a class="card topic-card" href={href}>
  <div class="topic-top">
    <span class="topic-icon" aria-hidden="true">{icon}</span>
    <span class="topic-cat">{category}</span>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  <span class="topic-count">
    {count} {count === 1 ? 'question' : 'questions'}
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
  </span>
  {ids.length > 0 && (
    <div class="topic-progress" data-progress-ids={JSON.stringify(ids)}>
      <div class="topic-progress-text">
        <span data-progress-count>0</span>/<span data-progress-total>{ids.length}</span> studied
        <span class="topic-progress-pct" data-progress-percent>0%</span>
      </div>
      <div class="pt-bar">
        <div class="pt-fill" style="width:0%"></div>
      </div>
    </div>
  )}
</a>

<style>
  .topic-card {
    display: flex;
    flex-direction: column;
    padding: 1.4rem;
    height: 100%;
  }
  .topic-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.9rem;
  }
  .topic-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 11px;
    background: var(--accent-soft);
    font-size: 1.25rem;
    line-height: 1;
  }
  .topic-cat {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-faint);
  }
  .topic-card h3 {
    margin: 0 0 0.4rem;
    font-size: 1.15rem;
  }
  .topic-card p {
    margin: 0;
    font-size: 0.92rem;
    flex: 1;
  }
  .topic-count {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1.1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
  }
  .topic-progress {
    margin-top: 0.9rem;
  }
  .topic-progress-text {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    font-size: 0.76rem;
    font-weight: 600;
    color: var(--ink-faint);
    margin-bottom: 0.4rem;
  }
  .topic-progress-text [data-progress-count] {
    color: var(--ink-soft);
  }
  .topic-progress-pct {
    margin-left: auto;
    color: var(--ink-soft);
  }
  .topic-progress.is-complete .topic-progress-pct,
  .topic-progress.is-complete .topic-progress-text [data-progress-count] {
    color: var(--accent);
  }
  .topic-progress .pt-bar {
    position: relative;
    height: 5px;
    border-radius: 999px;
    background: var(--surface-3);
    overflow: hidden;
  }
  .topic-progress .pt-fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright));
    transition: width 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
</style>

<script>
  import '../lib/progress';
</script>
