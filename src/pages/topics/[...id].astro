---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CoroutinesPrimer from '../../components/CoroutinesPrimer.astro';
import QuestionItem from '../../components/QuestionItem.astro';
import { DIFFICULTY_ORDER, DIFFICULTY_LABEL, SITE } from '../../consts';

export const getStaticPaths = (async () => {
  const topics = await getCollection('topics');
  return topics.map((topic) => ({
    params: { id: topic.id },
    props: { topic },
  }));
}) satisfies GetStaticPaths;

const { topic } = Astro.props;

const allQuestions = await getCollection('questions');
const questions = allQuestions
  .filter((q) => q.data.topic.id === topic.id)
  .sort(
    (a, b) =>
      DIFFICULTY_ORDER.indexOf(a.data.difficulty) -
        DIFFICULTY_ORDER.indexOf(b.data.difficulty) ||
      a.data.order - b.data.order ||
      a.data.question.localeCompare(b.data.question)
  );

// Pre-render each answer body.
const rendered = await Promise.all(
  questions.map(async (q) => ({ q, Content: (await render(q)).Content }))
);

const counts = DIFFICULTY_ORDER.map((d) => ({
  level: d,
  label: DIFFICULTY_LABEL[d],
  n: questions.filter((q) => q.data.difficulty === d).length,
})).filter((c) => c.n > 0);
const starredCount = questions.filter((q) => q.data.starred).length;

const levelIntro: Record<string, { title: string; description: string }> = {
  junior: {
    title: 'Start here',
    description: 'Core ideas you should be able to explain in plain language.',
  },
  mid: {
    title: 'Use it in practice',
    description: 'Common implementation choices, debugging, and trade-offs.',
  },
  senior: {
    title: 'Optional deep dives',
    description: 'Internals and broader design questions to study after the core material.',
  },
};

const sectionOrder: Record<string, string[]> = {
  kotlin: [
    'Language essentials',
    'Classes and modeling',
    'Functions and idioms',
    'Collections',
    'Error handling',
    'Type system and generics',
    'Java interoperability',
    'Advanced language features',
    'Code reasoning',
  ],
  coroutines: [
    'Coroutine foundations',
    'Scope ownership',
    'Flow foundations',
    'Flow operators',
    'State and lifecycle',
    'Practical Flow pipelines',
    'Flow sharing and reliability',
    'Channels and callback interop',
    'Shared-state safety',
    'Concurrency code reasoning',
  ],
  'jetpack-compose': [
    'Mental model',
    'State fundamentals',
    'State and recomposition',
    'Effects and lifecycle',
    'Layout and modifiers',
    'Lists',
    'Everyday UI',
    'App integration',
    'Performance',
    'Tooling',
    'Performance and runtime',
    'Core concepts',
  ],
  'code-snippet-output': [
    'Reading Kotlin',
    'Collections and evaluation',
    'Objects and dispatch',
    'Control flow',
  ],
};
const topicSectionOrder = sectionOrder[topic.id] ?? [];

const questionGroups = DIFFICULTY_ORDER.map((level) => {
  const items = rendered.filter(({ q }) => q.data.difficulty === level);
  const sections = [...new Set(items.map(({ q }) => q.data.section))]
    .sort((a, b) => {
      const ai = topicSectionOrder.indexOf(a);
      const bi = topicSectionOrder.indexOf(b);
      return (ai < 0 ? 999 : ai) - (bi < 0 ? 999 : bi) || a.localeCompare(b);
    })
    .map((section) => ({
      title: section,
      items: items.filter(({ q }) => q.data.section === section),
    }));
  return { level, ...levelIntro[level], items, sections };
}).filter((group) => group.items.length > 0);

const { Content: Overview } = await render(topic);
const hasOverview = topic.body && topic.body.trim().length > 0;
---
<BaseLayout title={topic.data.title} description={topic.data.description}>
  <section class="page-head">
    <div class="container">
      <a class="back" href="/topics/">← All topics</a>
      <div class="t-head">
        <span class="t-icon" aria-hidden="true">{topic.data.icon}</span>
        <div>
          <span class="eyebrow">{topic.data.category}</span>
          <h1>{topic.data.title}</h1>
        </div>
      </div>
      <p class="lede text-soft">{topic.data.description}</p>
      <div class="t-counts">
        <span class="count-pill">{questions.length} questions</span>
        {starredCount > 0 && <span class="count-pill priority-count">★ {starredCount} high priority</span>}
        {counts.map((c) => (
          <span class="count-pill">{c.n} {c.label.toLowerCase()}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="container topic-body">
    {hasOverview && (
      <div class="overview prose">
        <Overview />
      </div>
    )}

    {starredCount > 0 && (
      <p class="star-legend"><span aria-hidden="true">★</span> Frequently asked. Prioritize these in your first pass.</p>
    )}

    {topic.id === 'coroutines' && <CoroutinesPrimer />}

    {questions.length > 0 ? (
      <div class="q-list">
        {questionGroups.map((group) => (
          <section class="level-group" aria-labelledby={`${group.level}-heading`}>
            <div class="level-head">
              <h2 id={`${group.level}-heading`}>{group.title}</h2>
              <p>{group.description}</p>
            </div>
            {group.sections.map((section) => (
              <div class="concept-section">
                <h3>{section.title}</h3>
                {section.items.map(({ q, Content }) => (
                  <QuestionItem
                    id={q.id}
                    question={q.data.question}
                    difficulty={q.data.difficulty}
                    tags={q.data.tags}
                    starred={q.data.starred}
                  >
                    <Content />
                  </QuestionItem>
                ))}
              </div>
            ))}
          </section>
        ))}
      </div>
    ) : (
      <div class="empty card">
        <h3>No questions here yet</h3>
        <p class="text-soft">
          Be the first to add a question for {topic.data.title}. Drop a markdown
          file into <code>src/content/questions/</code> and open a pull request.
        </p>
        <a class="btn btn-primary" href="/contribute/">How to contribute</a>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(2rem, 5vw, 3rem) 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .back {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-soft);
  }
  .back:hover {
    color: var(--accent);
  }
  .t-head {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }
  .t-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 58px;
    height: 58px;
    border-radius: 14px;
    background: var(--accent-soft);
    font-size: 1.7rem;
    flex-shrink: 0;
  }
  .t-head h1 {
    margin: 0.15rem 0 0;
  }
  .page-head .lede {
    margin: 1rem 0 0;
    max-width: 640px;
    font-size: 1.05rem;
  }
  .t-counts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }
  .count-pill {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink-soft);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.25rem 0.7rem;
  }
  .priority-count,
  .star-legend span {
    color: #9a6700;
  }
  .star-legend {
    margin: 0 0 1.2rem;
    color: var(--ink-soft);
    font-size: 0.86rem;
  }
  .star-legend span {
    margin-right: 0.3rem;
  }
  :global(:root[data-theme='dark']) .priority-count,
  :global(:root[data-theme='dark']) .star-legend span {
    color: #f4bf58;
  }

  .topic-body {
    padding-block: 2.2rem 1rem;
    max-width: 860px;
  }
  .overview {
    margin-bottom: 2.2rem;
    padding-bottom: 1.8rem;
    border-bottom: 1px solid var(--border);
  }
  .q-list {
    margin-top: 0.5rem;
  }
  .level-group + .level-group {
    margin-top: 2.75rem;
  }
  .level-head {
    margin-bottom: 1rem;
  }
  .level-head h2 {
    margin: 0;
    font-size: 1.35rem;
  }
  .level-head p {
    color: var(--ink-soft);
    margin: 0.3rem 0 0;
    font-size: 0.93rem;
  }
  .concept-section + .concept-section {
    margin-top: 1.6rem;
  }
  .concept-section > h3 {
    margin: 0 0 0.65rem;
    color: var(--ink-soft);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .empty {
    padding: 2.5rem 2rem;
    text-align: center;
  }
  .empty h3 {
    margin: 0 0 0.5rem;
  }
  .empty p {
    margin: 0 auto 1.4rem;
    max-width: 440px;
  }
</style>
