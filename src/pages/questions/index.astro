---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuestionItem from '../../components/QuestionItem.astro';
import { DIFFICULTY_ORDER, DIFFICULTY_LABEL, SITE } from '../../consts';

const topics = await getCollection('topics');
const topicById = new Map(topics.map((t) => [t.id, t]));

const questions = (await getCollection('questions')).sort((a, b) => {
  const d =
    DIFFICULTY_ORDER.indexOf(a.data.difficulty) -
    DIFFICULTY_ORDER.indexOf(b.data.difficulty);
  if (d !== 0) return d;
  if (a.data.starred !== b.data.starred) return a.data.starred ? -1 : 1;
  return a.data.question.localeCompare(b.data.question);
});

const rendered = await Promise.all(
  questions.map(async (q) => ({ q, Content: (await render(q)).Content }))
);

// Topics that actually have questions, for the filter dropdown.
const usedTopics = [...new Set(questions.map((q) => q.data.topic.id))]
  .map((id) => topicById.get(id))
  .filter((t): t is NonNullable<typeof t> => Boolean(t))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));
---
<BaseLayout
  title="Question Bank"
  description="The full bank of Android interview questions - filter by topic and difficulty, search by keyword, and expand any question for a detailed answer."
>
  <section class="page-head">
    <div class="container">
      <span class="eyebrow">Question bank</span>
      <h1>Every question, in one place</h1>
      <p class="lede text-soft">
        {questions.length} questions across {usedTopics.length} topics. Filter,
        search, and expand for full answers. The Core view keeps Junior and Mid
        questions together; Senior is an optional deep dive.
      </p>
    </div>
  </section>

  <div class="container">
    <div class="filters" id="filters">
      <div class="search-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input
          id="q-search"
          type="search"
          placeholder="Search questions and tags…"
          autocomplete="off"
          aria-label="Search questions"
        />
      </div>

      <div class="filter-row">
        <div class="seg" role="group" aria-label="Filter by difficulty">
          <button class="seg-btn active" data-diff="core">Core</button>
          <button class="seg-btn" data-diff="all">All levels</button>
          {DIFFICULTY_ORDER.map((d) => (
            <button class="seg-btn" data-diff={d}>{DIFFICULTY_LABEL[d]}</button>
          ))}
        </div>

        <select id="q-topic" aria-label="Filter by topic">
          <option value="all">All topics</option>
          {usedTopics.map((t) => (
            <option value={t.id}>{t.data.title}</option>
          ))}
        </select>
      </div>
    </div>

    <p class="result-count" id="result-count" aria-live="polite"></p>

    {questions.length > 0 ? (
      <div class="q-list" id="q-list">
        {rendered.map(({ q, Content }) => {
          const topic = topicById.get(q.data.topic.id);
          const haystack = `${q.data.question} ${q.data.tags.join(' ')} ${
            topic?.data.title ?? ''
          }`.toLowerCase();
          return (
            <div
              class="q-wrap"
              data-diff={q.data.difficulty}
              data-topic={q.data.topic.id}
              data-search={haystack}
            >
              <QuestionItem
                id={q.id}
                question={q.data.question}
                difficulty={q.data.difficulty}
                tags={q.data.tags}
                starred={q.data.starred}
                topicTitle={topic?.data.title}
                topicHref={topic ? `/topics/${topic.id}/` : undefined}
              >
                <Content />
              </QuestionItem>
            </div>
          );
        })}
      </div>
      <p class="no-results" id="no-results" hidden>
        No questions match your filters. Try clearing the search.
      </p>
    ) : (
      <div class="empty card">
        <h3>The bank is empty - for now</h3>
        <p class="text-soft">
          Questions get added in the next phase, and by contributors. Want to
          seed the first one? See <a href="/contribute/">how to contribute</a>.
        </p>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-head {
    padding-block: clamp(2.5rem, 6vw, 4rem) 1rem;
  }
  .page-head .lede {
    max-width: 560px;
    margin-top: 0.7rem;
    font-size: 1.06rem;
  }
  .filters {
    position: sticky;
    top: 64px;
    z-index: 20;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    padding: 1rem 0 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0 0.9rem;
    color: var(--ink-faint);
  }
  .search-wrap:focus-within {
    border-color: var(--accent);
  }
  #q-search {
    flex: 1;
    border: none;
    background: transparent;
    padding: 0.7rem 0;
    font-size: 0.98rem;
    color: var(--ink);
    font-family: inherit;
  }
  #q-search:focus {
    outline: none;
  }
  .filter-row {
    display: flex;
    gap: 0.7rem;
    flex-wrap: wrap;
    justify-content: space-between;
  }
  .seg {
    display: inline-flex;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 3px;
    gap: 2px;
  }
  .seg-btn {
    border: none;
    background: transparent;
    color: var(--ink-soft);
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .seg-btn:hover {
    color: var(--ink);
  }
  .seg-btn.active {
    background: var(--surface);
    color: var(--accent);
    box-shadow: var(--shadow-sm);
  }
  #q-topic {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.45rem 0.8rem;
    color: var(--ink);
    font-size: 0.88rem;
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
  }
  #q-topic:focus {
    outline: none;
    border-color: var(--accent);
  }
  .result-count {
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin: 0.2rem 0 1.2rem;
  }
  .q-wrap[hidden] {
    display: none;
  }
  .no-results {
    text-align: center;
    color: var(--ink-faint);
    padding: 2rem;
  }
  .empty {
    padding: 2.5rem 2rem;
    text-align: center;
    margin-top: 1rem;
  }
  .empty h3 {
    margin: 0 0 0.5rem;
  }
  .empty p {
    margin: 0 auto;
    max-width: 440px;
  }
</style>

<script>
  const search = document.getElementById('q-search') as HTMLInputElement | null;
  const topicSel = document.getElementById('q-topic') as HTMLSelectElement | null;
  const segBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.seg-btn'));
  const items = Array.from(document.querySelectorAll<HTMLElement>('.q-wrap'));
  const countEl = document.getElementById('result-count');
  const noResults = document.getElementById('no-results');

  let diff = 'core';

  function apply() {
    const term = (search?.value ?? '').trim().toLowerCase();
    const topic = topicSel?.value ?? 'all';
    let shown = 0;

    for (const el of items) {
      const okDiff =
        diff === 'all' ||
        (diff === 'core' && el.dataset.diff !== 'senior') ||
        el.dataset.diff === diff;
      const okTopic = topic === 'all' || el.dataset.topic === topic;
      const okTerm = term === '' || (el.dataset.search ?? '').includes(term);
      const visible = okDiff && okTopic && okTerm;
      el.hidden = !visible;
      if (visible) shown++;
    }

    if (countEl) {
      countEl.textContent = `Showing ${shown} of ${items.length} questions`;
    }
    if (noResults) noResults.hidden = shown !== 0;
  }

  search?.addEventListener('input', apply);
  topicSel?.addEventListener('change', apply);
  segBtns.forEach((btn) =>
    btn.addEventListener('click', () => {
      segBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      diff = btn.dataset.diff ?? 'all';
      apply();
    })
  );

  // When arriving via a deep link (e.g. from global search: /questions/#<id>),
  // clear filters so the target isn't hidden, then open and reveal it.
  function revealFromHash() {
    const id = decodeURIComponent(location.hash.slice(1));
    if (!id) return;
    const target = document.getElementById(id);
    if (!target) return;
    diff = 'all';
    segBtns.forEach((b) => b.classList.toggle('active', b.dataset.diff === 'all'));
    if (topicSel) topicSel.value = 'all';
    if (search) search.value = '';
    apply();
    if (target instanceof HTMLDetailsElement) target.open = true;
    target.scrollIntoView({ block: 'start' });
  }

  window.addEventListener('hashchange', revealFromHash);

  apply();
  revealFromHash();
</script>
