---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicCard from '../components/TopicCard.astro';
import { SITE } from '../consts';

const topics = await getCollection('topics');
const questions = await getCollection('questions');
const experiences = (await getCollection('experiences')).filter((e) => !e.data.draft);
const posts = (await getCollection('blog')).filter((p) => !p.data.draft);

const countFor = (topicId: string) =>
  questions.filter((q) => q.data.topic.id === topicId).length;

// Featured topics: most questions first, then by manual order.
const featured = [...topics]
  .sort((a, b) => {
    const diff = countFor(b.id) - countFor(a.id);
    return diff !== 0 ? diff : a.data.order - b.data.order;
  })
  .slice(0, 6);

const stats = [
  { value: questions.length, label: 'Interview questions' },
  { value: topics.length, label: 'Curated topics' },
  { value: experiences.length, label: 'Interview experiences' },
  { value: posts.length, label: 'Guides & articles' },
];

const features = [
  {
    icon: '◳',
    title: 'Topic-by-topic guides',
    body: 'Coroutines, Compose, Jetpack, DI, system design - organized so you can drill the exact areas you are rusty on.',
  },
  {
    icon: '❓',
    title: 'A real question bank',
    body: 'Every question is a standalone, reviewable entry tagged by difficulty - filter from junior warm-ups to senior deep-dives.',
  },
  {
    icon: '◎',
    title: 'Real interview experiences',
    body: 'First-hand write-ups of actual interviews: rounds, questions asked, and what the hiring bar looked like. Names can be withheld.',
  },
  {
    icon: '⌥',
    title: 'Open source, forever',
    body: 'No paywall, no sign-up. The whole thing lives on GitHub - fix a typo or add your experience with a single pull request.',
  },
];
---
<BaseLayout>
  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="eyebrow">
        <span class="dot"></span> Open-source interview prep for Android engineers
      </span>
      <h1>
        Switch jobs in Android dev<br />
        with <span class="grad">zero guesswork</span>.
      </h1>
      <p class="lede">
        {SITE.name} is a community-built kit of curated questions, topic
        deep-dives, and real interview experiences. Use it to prepare for your
        next Android interview without piecing together a dozen sources.
      </p>
      <div class="hero-cta">
        <a class="btn btn-primary" href="/topics/">
          Browse topics
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a class="btn btn-ghost" href="/experiences/">Read interview experiences</a>
      </div>
      <div class="hero-stats">
        {stats.map((s) => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- ===== Featured topics ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Start here</span>
          <h2>Popular topics</h2>
        </div>
        <a class="see-all" href="/topics/">View all topics →</a>
      </div>

      {featured.length > 0 ? (
        <div class="grid grid-3">
          {featured.map((t) => (
            <TopicCard
              href={`/topics/${t.id}/`}
              title={t.data.title}
              description={t.data.description}
              category={t.data.category}
              icon={t.data.icon}
              count={countFor(t.id)}
            />
          ))}
        </div>
      ) : (
        <div class="empty card">
          <p>
            No topics yet - this is step one. Topics and questions get added in
            the next phase, or by the community via
            <a href={SITE.github}> pull requests</a>.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- ===== Features ===== -->
  <section class="section feature-band">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Why AndroidDevKit</span>
        <h2>Everything for the switch, in one place</h2>
        <p class="text-soft section-sub">
          Stop stitching together scattered blog posts and outdated Gists. This
          is a single, maintained source of truth.
        </p>
      </div>
      <div class="grid grid-2 feature-grid">
        {features.map((f) => (
          <div class="card feature-card">
            <span class="feature-icon" aria-hidden="true">{f.icon}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== Contribute CTA ===== -->
  <section class="section">
    <div class="container">
      <div class="cta-card">
        <div class="cta-text">
          <span class="eyebrow">Give back</span>
          <h2>Just finished an interview? Pay it forward.</h2>
          <p class="text-soft">
            The best prep material comes from people who just sat in the chair.
            Add a question, fix an answer, or write up your interview experience
            - it all happens through GitHub pull requests.
          </p>
          <div class="hero-cta">
            <a class="btn btn-primary" href="/contribute/">How to contribute</a>
            <a class="btn btn-ghost" href={SITE.github} target="_blank" rel="noopener noreferrer">Star on GitHub</a>
          </div>
        </div>
        <div class="cta-deco" aria-hidden="true">
          <pre><code>{`$ git checkout -b add-coroutines-q
$ # add your question file
$ git commit -m "Add: structured concurrency Q"
$ git push origin add-coroutines-q
# → open a Pull Request 🎉`}</code></pre>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem) clamp(2.5rem, 6vw, 4rem);
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .eyebrow .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent-bright);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .hero h1 {
    margin: 1.1rem 0 0;
    font-size: clamp(2.3rem, 6vw, 4rem);
  }
  .grad {
    background: linear-gradient(100deg, var(--accent) 10%, var(--accent-bright) 90%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    max-width: 620px;
    margin: 1.3rem 0 0;
    font-size: 1.12rem;
    color: var(--ink-soft);
  }
  .hero-cta {
    display: flex;
    gap: 0.8rem;
    margin-top: 1.9rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(1.5rem, 5vw, 3.5rem);
    margin-top: 3.2rem;
    padding-top: 2.2rem;
    border-top: 1px solid var(--border);
    width: 100%;
    max-width: 720px;
  }
  .stat {
    display: flex;
    flex-direction: column;
  }
  .stat-value {
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .stat-label {
    font-size: 0.82rem;
    color: var(--ink-faint);
  }
  .hero-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 600px;
    background: radial-gradient(
      ellipse at center,
      color-mix(in srgb, var(--accent-bright) 22%, transparent),
      transparent 62%
    );
    filter: blur(20px);
    z-index: 0;
    pointer-events: none;
  }

  .section-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .section-head h2 {
    margin: 0.4rem 0 0;
  }
  .section-head.center {
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .section-sub {
    max-width: 560px;
    margin: 0.6rem 0 0;
  }
  .see-all {
    font-weight: 600;
    font-size: 0.92rem;
    white-space: nowrap;
  }

  .feature-band {
    background: var(--surface);
    border-block: 1px solid var(--border);
  }
  .feature-grid {
    margin-top: 2.5rem;
  }
  .feature-card {
    padding: 1.6rem;
  }
  .feature-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }
  .feature-card h3 {
    margin: 0 0 0.45rem;
  }
  .feature-card p {
    margin: 0;
    font-size: 0.94rem;
  }

  .empty {
    padding: 2rem;
    text-align: center;
  }
  .empty p {
    margin: 0;
  }

  .cta-card {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2.5rem;
    align-items: center;
    padding: clamp(1.8rem, 4vw, 3rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at 0% 0%, var(--accent-soft), transparent 55%),
      var(--surface);
  }
  .cta-text h2 {
    margin: 0.4rem 0 0.7rem;
  }
  .cta-text p {
    margin: 0 0 1.4rem;
  }
  .cta-deco pre {
    background: var(--bg);
    margin: 0;
    font-size: 0.82rem;
  }
  .cta-deco code {
    color: var(--ink-soft);
    white-space: pre-wrap;
  }

  @media (max-width: 760px) {
    .cta-card {
      grid-template-columns: 1fr;
    }
    .cta-deco {
      display: none;
    }
  }
</style>
